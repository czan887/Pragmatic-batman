# Twitter Bot v2.0 - Environment Configuration
# Copy this file to .env and fill in your values

# ========== AdsPower Configuration ==========
ADSPOWER_URL=http://localhost:50325
ADSPOWER_API_KEY=your_adspower_api_key_here

# ========== AI API Keys ==========
# Google Gemini (for content generation)
GEMINI_API_KEY=your_gemini_api_key_here

# Anthropic Claude (for profile analysis and selector recovery)
# Optional - disable AI features if not provided
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ========== Server Configuration ==========
HOST=0.0.0.0
PORT=8080
DEBUG=false

# ========== SSL Configuration ==========
# Uncomment and set these for HTTPS
# SSL_CERTFILE=ssl/cert.pem
# SSL_KEYFILE=ssl/key.pem

# ========== Database ==========
DATABASE_PATH=twitter_bot.db

# ========== Bot Settings ==========
DEFAULT_BATCH_SIZE=15
DEFAULT_BATCH_DELAY_MINUTES=60
MIN_ACTION_DELAY=2.0
MAX_ACTION_DELAY=5.0

# ========== AI Features ==========
AI_MODEL=gemini-2.0-flash
ENABLE_PROFILE_ANALYSIS=true
ENABLE_BEHAVIOR_PLANNING=true
ENABLE_MCP_RECOVERY=true

# ========== CORS Origins ==========
# Comma-separated list of allowed origins
ALLOWED_ORIGINS=http://localhost:3000,http://10.8.0.1:3000
